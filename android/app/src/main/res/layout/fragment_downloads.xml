<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Speed bar at top -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        android:background="@color/dark_surface">

        <TextView
            android:id="@+id/tv_total_speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_pause_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pause"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_resume_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resume"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_clear_done"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear done"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No downloads yet"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="Tap ＋ to paste a URL and download\n\nTo grab from Chrome: long-press any link\n→ Share → Lumi DM\n\nCopied a download link? It will appear\nautomatically below." />

    </LinearLayout>

    <!-- Download list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_downloads"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
