<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- URL input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="URL"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="https://…"
            android:inputType="textUri"
            android:imeOptions="actionNext"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Type selector -->
        <RadioGroup
            android:id="@+id/rg_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <RadioButton
                android:id="@+id/rb_http"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Direct download"
                android:textColor="@color/text_primary"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_video"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Video / YouTube"
                android:textColor="@color/text_primary" />

        </RadioGroup>

        <!-- Video section (shown when Video selected) -->
        <LinearLayout
            android:id="@+id/ll_video_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_analyse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analyse Video"
                android:backgroundTint="@color/dark_surface"
                android:textColor="@color/accent" />

            <ProgressBar
                android:id="@+id/pb_analyse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quality"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinner_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_background"
                android:padding="4dp"
                android:popupBackground="@color/dark_surface" />

        </LinearLayout>

        <!-- Filename (optional) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Filename (optional)"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="Leave empty to auto-detect"
            android:inputType="text"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Error message -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/red"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Download button -->
        <Button
            android:id="@+id/btn_download"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Download"
            android:backgroundTint="@color/accent"
            android:textColor="#ffffff"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
